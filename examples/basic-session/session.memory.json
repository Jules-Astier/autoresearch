{
  "slug": "basic-model-search-memory",
  "title": "Basic model search with durable memory",
  "repoPath": "../target-project",
  "baseRef": "HEAD",
  "benchmarkCommand": "npm test -- --json",
  "computeBudget": { "seconds": 300 },
  "targetExperimentCount": 10,
  "maxConcurrentRuns": 1,
  "maxPlannedConcurrentExperiments": 3,
  "preemptivePlanning": true,
  "editablePaths": [
    "src/model.ts",
    "config/tunable.json"
  ],
  "immutablePaths": [
    "data/**",
    "config/fixed.json"
  ],
  "runtimeConfigPaths": [
    "config/tunable.json"
  ],
  "workspaceLinks": [],
  "modelIoContract": "Preserve the existing command line interface and metric output.",
  "agent": {
    "provider": "codex",
    "model": "gpt-5.4",
    "effort": "high",
    "researcher": { "model": "gpt-5.4", "effort": "high" },
    "planner": { "model": "gpt-5.4", "effort": "high" },
    "reviewer": { "model": "gpt-5.4", "effort": "high" },
    "worker": { "model": "gpt-5.4", "effort": "high" },
    "memoryKeeper": { "model": "gpt-5.4", "effort": "high" }
  },
  "memory": {
    "enabled": true,
    "rootPath": "research",
    "referencePaths": [
      "references"
    ]
  },
  "sandbox": { "environment": "none" },
  "metricContract": {
    "rankingMode": "lexicographic",
    "metrics": [
      { "name": "validation_loss", "direction": "minimize", "role": "objective" },
      { "name": "accuracy", "direction": "maximize", "role": "objective" }
    ]
  }
}
