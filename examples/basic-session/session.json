{
  "slug": "basic-model-search",
  "title": "Basic model search",
  "repoPath": "../target-project",
  "baseRef": "HEAD",
  "benchmarkCommand": "npm test -- --json",
  "computeBudget": { "seconds": 300 },
  "targetExperimentCount": 10,
  "maxConcurrentRuns": 1,
  "maxPlannedConcurrentExperiments": 3,
  "editablePaths": [
    "src/model.ts",
    "config/tunable.json"
  ],
  "immutablePaths": [
    "data/**",
    "config/fixed.json"
  ],
  "runtimeConfigPaths": [
    "config/tunable.json"
  ],
  "workspaceLinks": [],
  "modelIoContract": "Preserve the existing command line interface and metric output.",
  "memory": {
    "enabled": true,
    "rootPath": "research",
    "researcher": { "enabled": true },
    "memoryKeeper": { "enabled": true }
  },
  "sandbox": { "environment": "none" },
  "metricContract": {
    "rankingMode": "lexicographic",
    "metrics": [
      { "name": "validation_loss", "direction": "minimize", "role": "objective" },
      { "name": "accuracy", "direction": "maximize", "role": "objective" }
    ]
  }
}
